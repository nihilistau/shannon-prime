// GLSL Compute Shader: Möbius squarefree-first permutation
//
// Reorders VHT2 coefficients so squarefree indices come first.
// This is a gather operation: output[i] = input[order[i]]
//
// The Möbius mask is a property of the VHT2 spectrum, not the model.
// Cross-platform invariant: K correlation 0.997 on both hd=128 and hd=64.

#version 450

layout(local_size_x = 128) in;

layout(set = 0, binding = 0) readonly buffer Input {
    float input_data[];
};

layout(set = 0, binding = 1) writeonly buffer Output {
    float output_data[];
};

layout(set = 0, binding = 2) readonly buffer Order {
    int order[];  // Permutation table: order[i] = source index
};

layout(push_constant) uniform PushConstants {
    uint n;         // Vector length
    uint n_vecs;    // Number of vectors
};

void main() {
    uint vec_idx = gl_WorkGroupID.x;
    uint tid     = gl_LocalInvocationID.x;

    if (vec_idx >= n_vecs || tid >= n) return;

    uint out_off = vec_idx * n + tid;
    uint in_off  = vec_idx * n + uint(order[tid]);

    output_data[out_off] = input_data[in_off];
}
